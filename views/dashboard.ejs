      async function exportKeys(filterStr) {
        try {
          const res = await fetch("/api/jx/keys/export", {
            headers: { Authorization: "Bearer " + token },
          });
          const data = await res.json();
          if (!data.ok) throw new Error("Failed to export");
          let keysToExport = data.keys;
          if (filterStr === "giveaway") {
             keysToExport = keysToExport.filter(k => k.tier === "giveaway");
          }
          const payload =
            filterStr === "all"
              ? data
              : { keys: keysToExport, requests: data.requests || [], settings: data.settings || {}, stats: data.stats || {} };
          const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
          const url = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = url;
          a.download = `jx_keys_${filterStr}_backup_${new Date().toISOString().split('T')[0]}.json`;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
          toast("Exported!");
        } catch (err) {
          toast(err.message);
        }
      }

      // Add Import logic
      function setupImport(btnId, fileInputId) {
        const btn = document.getElementById(btnId);
        const fileInput = document.getElementById(fileInputId);
        btn.onclick = () => fileInput.click();
        fileInput.onchange = (e) => {
          const file = e.target.files[0];
          if (!file) return;
          const reader = new FileReader();
          reader.onload = async (event) => {
            try {
              const payload = JSON.parse(event.target.result);
              const res = await fetch("/api/jx/keys/import", {
                method: "POST",
                headers: { "Content-Type": "application/json", Authorization: "Bearer " + token },
                body: JSON.stringify(payload)
              });
              const data = await res.json();
              if (!data.ok) throw new Error(data.message || "Failed to import");
              toast(`Imported ${data.count} keys successfully!`);
              loadKeys();
              loadUnused();
              loadGiveaways();
              loadStats();
            } catch (err) {
              toast("Import error: " + err.message);
            }
            fileInput.value = "";
          };
          reader.readAsText(file);
        };
      }
