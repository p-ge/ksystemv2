<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JX Dashboard</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="page" style="padding-top: 24px;">
      <div style="width: 1100px; max-width: 100%;">
        <div class="row" style="align-items: center; justify-content: space-between; margin-bottom: 16px;">
          <div class="row" style="align-items: center; gap: 12px;">
            <div class="logo-wrap" style="width: 60px; height: 60px; border-radius: 50%; margin: 0; overflow: hidden;">
              <img src="/logo.png" alt="Logo" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
            </div>
            <div>
              <h2 id="dash-title" style="margin: 0;">JX Dashboard</h2>
              <p class="muted" style="margin: 2px 0 0;">PIN + 2FA protected · Prefix <span class="code"><%= settings.prefix %></span></p>
            </div>
          </div>
          <button id="logout" class="btn btn-ghost">Logout</button>
        </div>

        <div class="tabs" style="margin-bottom: 14px;">
          <div class="tab active" data-tab="tab-dashboard">Dashboard</div>
          <div class="tab" data-tab="tab-keys">Keys</div>
          <div class="tab" data-tab="tab-universal">Universal Key</div>
          <div class="tab" data-tab="tab-giveaway">Giveaways</div>
          <div class="tab" data-tab="tab-test">Test</div>
          <div class="tab" data-tab="tab-bot">Bot</div>
          <div class="tab" data-tab="tab-settings">Settings</div>
        </div>

        <div id="tab-dashboard" class="panel">
          <div class="stat-grid">
            <div class="stat">
              <small>Total Generated</small>
              <strong id="stat-total">0</strong>
            </div>
            <div class="stat">
              <small>Active Keys</small>
              <strong id="stat-active">0</strong>
            </div>
            <div class="stat" id="stat-requests-wrap">
              <small>Pending Requests</small>
              <strong id="stat-requests">0</strong>
            </div>
          </div>
          <div class="box" style="margin-top: 15px; border: 1px solid var(--border); padding: 15px; border-radius: var(--radius); text-align: center;">
            <p style="margin-bottom: 10px; color: var(--text-muted)">Master Backup Engine</p>
            <div class="row" style="justify-content: center; gap: 10px;">
              <button id="master-export-keys" class="btn btn-primary">Download All Keys</button>
              <button id="master-import-keys" class="btn btn-primary outline">Load Keys</button>
              <input type="file" id="master-import-keys-file" accept=".json" style="display:none;" />
            </div>
            <p class="muted" style="margin-top: 10px; font-size: 0.8rem;">Downloads ALL parameters including universal, giveaways, unused list, and general database entries inside one global backup.</p>
          </div>
        </div>

        <div id="tab-keys" class="panel" style="display: none;">
          <div class="tabs" style="margin-bottom: 12px;">
            <div class="tab active" data-sub="request" id="tab-sub-request">Request Key</div>
            <div class="tab" data-sub="list">Keys List</div>
            <div class="tab" data-sub="unused">Unused Keys</div>
            <div class="tab" data-sub="generate">Generate Key</div>
          </div>

          <div data-subpanel="request" id="subpanel-request">
            <label>HWID</label>
            <input id="req-hwid" placeholder="User HWID / unique identifier" />
            <button id="req-btn" class="btn btn-primary" style="margin-top: 10px;">Request Key (auto-approve)</button>
            <p class="muted" style="margin-top: 8px;">Requests auto-expire after 20 minutes of inactivity.</p>
          </div>

          <div data-subpanel="list" style="display: none;">
            <div class="row" style="align-items: center; margin-bottom: 10px; gap: 8px; flex-wrap: wrap;">
              <div class="row" style="align-items: center; gap: 6px;">
                <select id="filter">
                  <option value="all">All</option>
                  <option value="active">Active</option>
                  <option value="free">Free</option>
                  <option value="premium">Premium</option>
                  <option value="expired">Expired</option>
                  <option value="unused">Unused</option>
                </select>
                <button id="refresh" class="btn btn-ghost">Refresh</button>
                <button id="export-keys" class="btn btn-ghost">Download All Keys</button>
                <button id="import-keys" class="btn btn-ghost">Load Keys</button>
                <input type="file" id="import-keys-file" accept=".json" style="display:none;" />
              </div>
              <input
                id="key-search"
                type="text"
                placeholder="Search by key or HWID..."
                style="flex: 1 1 220px; max-width: 360px;"
              />
            </div>
            <div style="overflow: auto;">
              <table class="table" id="keys-table">
                <thead>
                  <tr>
                    <th>Key</th>
                    <th>HWID</th>
                    <th>Tier</th>
                    <th>Expires</th>
                    <th>Status</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>

          <div data-subpanel="unused" style="display: none;">
            <div class="row" style="align-items: center; margin-bottom: 10px;">
              <button id="refresh-unused" class="btn btn-ghost">Refresh</button>
            </div>
            <div style="overflow: auto;">
              <table class="table" id="unused-table">
                <thead>
                  <tr>
                    <th>Key</th>
                    <th>HWID</th>
                    <th>Tier</th>
                    <th>Expires</th>
                    <th>Status</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>

          <div data-subpanel="generate" style="display: none;">
            <div class="two-col grid">
              <div>
                <label>HWID (optional for premium/free)</label>
                <input id="gen-hwid" placeholder="Leave blank for unbound" />
              </div>
              <div>
                <label>Tier</label>
                <select id="gen-tier">
                  <option value="premium">Premium</option>
                  <option value="free">Free</option>
                </select>
              </div>
            </div>
            <label>Expiration</label>
            <div class="row">
              <button class="btn btn-ghost exp" data-hours="12">12h</button>
              <button class="btn btn-ghost exp" data-hours="24">24h</button>
              <button class="btn btn-ghost exp" data-hours="24">1d</button>
              <button class="btn btn-ghost exp" data-hours="720">1m</button>
              <button class="btn btn-ghost exp" data-hours="8760">1y</button>
              <button class="btn btn-ghost exp" data-hours="87600">10y</button>
              <button class="btn btn-ghost exp" data-hours="lifetime">Lifetime</button>
            </div>
            <label>Custom Hours</label>
            <input id="gen-hours" type="number" min="1" placeholder="e.g., 48 for 2 days" />
            <button id="gen-btn" class="btn btn-primary" style="margin-top: 12px;">Generate Key</button>
          </div>
        </div>

        <div id="tab-universal" class="panel" style="display: none;">
          <div class="tabs" style="margin-bottom: 12px;">
            <div class="tab active" data-sub="univ-list">Universal Key List</div>
            <div class="tab" data-sub="univ-generate">Generate Universal Key</div>
          </div>

          <div data-subpanel="univ-list">
            <div class="row" style="align-items: center; margin-bottom: 10px;">
              <button id="refresh-univ" class="btn btn-ghost">Refresh</button>
            </div>
            <div style="overflow: auto;">
              <table class="table" id="univ-table">
                <thead>
                  <tr>
                    <th>Key</th>
                    <th>Tier</th>
                    <th>Expires</th>
                    <th>Status</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>

          <div data-subpanel="univ-generate" style="display: none;">
            <label>Expiration</label>
            <div class="row">
              <button class="btn btn-ghost exp" data-hours="12">12h</button>
              <button class="btn btn-ghost exp" data-hours="24">24h</button>
              <button class="btn btn-ghost exp" data-hours="720">1m</button>
              <button class="btn btn-ghost exp" data-hours="lifetime">Lifetime</button>
            </div>
            <label>Custom Hours</label>
            <input id="gen-univ-hours" type="number" min="1" placeholder="e.g., 48 for 2 days" />
            <button id="gen-univ-btn" class="btn btn-primary" style="margin-top: 12px;">Generate Universal Key</button>
            <p class="muted" style="margin-top: 8px;">Universal keys bypass all HWID locks natively. Any client device can authenticate with one simultaneously.</p>
          </div>
        </div>

        <div id="tab-giveaway" class="panel" style="display: none;">
          <div class="tabs" style="margin-bottom: 12px;">
            <div class="tab active" data-sub="giveaway-list">All Giveaway Keys</div>
            <div class="tab" data-sub="giveaway-unused">Unused Giveaways</div>
            <div class="tab" data-sub="giveaway-generate">Generate Giveaway Key</div>
          </div>

          <div data-subpanel="giveaway-list">
            <div class="row" style="align-items: center; margin-bottom: 10px; gap: 8px; flex-wrap: wrap;">
              <div class="row" style="align-items: center; gap: 6px;">
                <button id="refresh-giveaway" class="btn btn-ghost">Refresh</button>
                <button id="export-giveaway" class="btn btn-ghost">Download All Giveaway Keys</button>
                <button id="import-giveaway" class="btn btn-ghost">Load Giveaway Keys</button>
                <input type="file" id="import-giveaway-file" accept=".json" style="display:none;" />
              </div>
            </div>
            <div style="overflow: auto;">
              <table class="table" id="giveaway-table">
                <thead>
                  <tr>
                    <th>Key</th>
                    <th>HWID</th>
                    <th>Expires</th>
                    <th>Status</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>

          <div data-subpanel="giveaway-unused" style="display: none;">
            <div class="row" style="align-items: center; margin-bottom: 10px; gap: 8px; flex-wrap: wrap;">
              <div class="row" style="align-items: center; gap: 6px;">
                <button id="refresh-giveaway-unused" class="btn btn-ghost">Refresh</button>
                <button id="export-giveaway-unused" class="btn btn-ghost">Download Unused Giveaways</button>
                <button id="import-giveaway-unused" class="btn btn-ghost">Load Giveaways</button>
                <input type="file" id="import-giveaway-unused-file" accept=".json" style="display:none;" />
              </div>
            </div>
            <div style="overflow: auto;">
              <table class="table" id="giveaway-unused-table">
                <thead>
                  <tr>
                    <th>Key</th>
                    <th>HWID</th>
                    <th>Expires</th>
                    <th>Status</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>

          <div data-subpanel="giveaway-generate" style="display: none;">
            <label>Expiration</label>
            <div class="row">
              <button class="btn btn-ghost exp" data-hours="12">12h</button>
              <button class="btn btn-ghost exp" data-hours="24">24h</button>
              <button class="btn btn-ghost exp" data-hours="720">1m</button>
              <button class="btn btn-ghost exp" data-hours="lifetime">Lifetime</button>
            </div>
            <label>Custom Hours</label>
            <input id="gen-giveaway-hours" type="number" min="1" placeholder="e.g., 48 for 2 days" />
            <button id="gen-giveaway-btn" class="btn btn-primary" style="margin-top: 12px;">Generate Giveaway Key</button>
          </div>
        </div>

        <div id="tab-settings" class="panel" style="display: none;">
          <div class="two-col grid">
            <div>
              <label>Key Prefix</label>
              <input id="set-prefix" value="<%= settings.prefix %>" />
            </div>
            <div>
              <label>Default Checkpoints</label>
              <input id="set-checkpoints" type="number" min="1" value="<%= settings.checkpoints %>" />
            </div>
            <div>
              <label>Default Expiration (hours)</label>
              <input id="set-exp" type="number" min="1" value="<%= settings.expirationHours %>" />
            </div>
            <div>
              <label>Generate Limit Per HWID</label>
              <input id="set-generate-limit" type="number" min="1" value="<%= settings.generateLimit || 3 %>" />
            </div>
            <div>
              <label>Add Time To Existing Key (hours)</label>
              <input id="set-add-time-hours" type="number" min="1" value="<%= settings.addTimeHours || 12 %>" />
            </div>
            <div>
              <label>Start Button Cooldown (minutes)</label>
              <input id="set-start-cooldown-mins" type="number" min="1" value="<%= settings.startCooldownMinutes || 5 %>" />
            </div>
            <div>
              <label>Plus Time Cooldown (hours)</label>
              <input id="set-plus-time-cooldown-hours" type="number" min="1" value="<%= settings.plusTimeCooldownHours || 12 %>" />
            </div>
            <div>
              <label>Plus Time Uses Before Cooldown</label>
              <input id="set-plus-time-uses" type="number" min="1" value="<%= settings.plusTimeUsesBeforeCooldown || 2 %>" />
            </div>
            <div>
              <label>Test Key Auto Delete (hours)</label>
              <input id="set-test-key-hours" type="number" min="1" value="<%= settings.testKeyHours || 48 %>" />
            </div>
            <div>
              <label>Token Limit</label>
              <input id="set-token-limit" type="number" min="1" value="<%= typeof settings.tokenLimit !== 'undefined' ? settings.tokenLimit : 3 %>" />
            </div>
            <div>
              <label>Token Limit to Genrate key</label>
              <input id="set-token-limit-generate" type="number" min="0" value="<%= typeof settings.tokenLimitGenerateKey !== 'undefined' ? settings.tokenLimitGenerateKey : 3 %>" />
            </div>
            <div>
              <label>Token Limit to Extend Key</label>
              <input id="set-token-limit-extend" type="number" min="0" value="<%= typeof settings.tokenLimitExtendKey !== 'undefined' ? settings.tokenLimitExtendKey : 3 %>" />
            </div>
            <div>
              <label>Token Limit To Buy</label>
              <input id="set-token-limit-buy" type="number" min="1" value="<%= typeof settings.tokenLimitToBuy !== 'undefined' ? settings.tokenLimitToBuy : 9 %>" />
            </div>
            <div>
              <label>Keyless Mode</label>
              <div class="row">
                <label class="muted"><input id="set-keyless" type="checkbox" <%= settings.keyless ? 'checked' : '' %> /> Enable</label>
              </div>
            </div>
            <div>
              <label>JX-Guest</label>
              <div class="row">
                <label class="muted"><input id="set-guest-enabled" type="checkbox" <%= settings.guestEnabled !== false ? 'checked' : '' %> /> Allow JX-Guest login (PIN 0000 + 2FA 000001)</label>
              </div>
            </div>
            <div>
              <label>Anti Bypass</label>
              <div class="row">
                <label class="muted"><input id="set-anti-bypass" type="checkbox" <%= settings.antiBypass !== false ? 'checked' : '' %> /> Enable stricter anti-bypass checks</label>
              </div>
            </div>
            <div>
              <label>Anti Extension (Tampermonkey / Violentmonkey)</label>
              <div class="row">
                <label class="muted"><input id="set-anti-extension" type="checkbox" <%= settings.antiExtension !== false ? 'checked' : '' %> /> Block while these extensions are detected</label>
              </div>
            </div>
            <div>
              <label>Bind Premium Key</label>
              <div class="row">
                <label class="muted"><input id="set-bind-premium-key" type="checkbox" <%= settings.bindPremiumKey !== false ? 'checked' : '' %> /> Require premium key activation via bot</label>
              </div>
            </div>
          </div>
          <hr style="margin:16px 0;border:none;border-top:1px solid rgba(148,163,184,0.35);" />
          <div class="two-col grid">
            <div style="grid-column:1 / -1;">
              <label>Boost Mode</label>
              <div class="row">
                <label class="muted"><input id="set-boost-enabled" type="checkbox" <%= settings.boostMode && settings.boostMode.enabled ? 'checked' : '' %> /> Enable 5s support screen before checkpoints</label>
              </div>
            </div>
            <div>
              <label>Boost: Like YouTube Video (link)</label>
              <input id="set-boost-like" type="url" placeholder="https://..." value="<%= settings.boostMode && settings.boostMode.likeUrl ? settings.boostMode.likeUrl : '' %>" />
            </div>
            <div>
              <label>Boost: Subscribe Channel (link)</label>
              <input id="set-boost-subscribe" type="url" placeholder="https://..." value="<%= settings.boostMode && settings.boostMode.subscribeUrl ? settings.boostMode.subscribeUrl : '' %>" />
            </div>
            <div>
              <label>Boost: Join Discord Server (link)</label>
              <input id="set-boost-discord" type="url" placeholder="https://..." value="<%= settings.boostMode && settings.boostMode.discordUrl ? settings.boostMode.discordUrl : '' %>" />
            </div>
          </div>
          <hr style="margin:16px 0;border:none;border-top:1px solid rgba(148,163,184,0.35);" />
          <div class="two-col grid">
            <div style="grid-column:1 / -1;">
              <label>Tutorial Video</label>
              <div class="row">
                <label class="muted"><input id="set-tutorial-enabled" type="checkbox" <%= settings.tutorial && settings.tutorial.enabled ? 'checked' : '' %> /> Show tutorial link on service selection & checkpoints</label>
              </div>
            </div>
            <div style="grid-column:1 / -1;">
              <label>Tutorial Video Link</label>
              <input id="set-tutorial-url" type="text" placeholder="https://youtube.com/watch?v=... or <iframe ...></iframe>" value="<%= settings.tutorial && settings.tutorial.url ? settings.tutorial.url : '' %>" />
            </div>
          </div>
          <button id="save-settings" class="btn btn-primary" style="margin-top: 12px;">Save Settings</button>
        </div>

        <div id="tab-test" class="panel" style="display:none;">
          <h3 style="margin:0 0 10px;">Checkpoint System Test</h3>
          <p class="muted" style="margin-bottom:12px;">Generate a temporary test HWID/checkpoint link (auto cleanup in 2 days by default).</p>
          <div class="row" style="gap:8px;align-items:center;">
            <button id="gen-test-checkpoint" class="btn btn-primary">Generate Test Checkpoint</button>
          </div>
          <label>Generated Test Checkpoint URL</label>
          <div class="row" style="gap:8px;">
            <input id="test-checkpoint-url" readonly placeholder="Click generate..." />
            <button id="copy-test-checkpoint-url" class="btn btn-ghost">Copy</button>
          </div>
          <label>Generated Test HWID</label>
          <input id="test-hwid" readonly placeholder="Will appear after generation" />
        </div>

        <div id="tab-bot" class="panel" style="display:none;">
          <h3 style="margin:0 0 10px;">Discord Bot</h3>
          <div class="tabs" data-subset="true" style="margin-bottom: 12px;">
            <div class="tab active" data-sub="bot-key">Key</div>
            <div class="tab" data-sub="bot-ticket">Ticket</div>
          </div>
          <div data-subpanel="bot-key">
            <p class="muted" style="margin-bottom:12px;">Key bot connection for premium commands.</p>
            <div class="two-col grid">
              <div style="grid-column:1 / -1;">
                <label>Discord Application ID (Client ID)</label>
                <input id="bot-app-id" type="text" placeholder="Paste bot application/client id" value="<%= settings.bot && settings.bot.appId ? settings.bot.appId : '' %>" />
              </div>
              <div style="grid-column:1 / -1;">
                <label>Discord Bot Token</label>
                <input id="bot-token" type="password" placeholder="Paste bot token" value="<%= settings.bot && settings.bot.token ? settings.bot.token : '' %>" />
              </div>
              <div style="grid-column:1 / -1;">
                <label>Activation Token</label>
                <div class="row" style="gap:8px;">
                  <input id="bot-activation-token" readonly value="<%= settings.bot && settings.bot.activationToken ? settings.bot.activationToken : '' %>" />
                  <button id="bot-copy-activation-token" class="btn btn-ghost">Copy</button>
                  <button id="bot-regenerate-activation-token" class="btn btn-ghost">Regenerate</button>
                </div>
              </div>
            </div>
            <button id="bot-save" class="btn btn-primary" style="margin-top: 12px;">Save Bot Config</button>
            <div style="margin-top: 16px; border-top: 1px solid var(--border); padding-top: 12px;">
              <p class="muted" style="margin-bottom:8px;">Manual premium activation (works even if key bot is offline).</p>
              <div class="two-col grid">
                <div>
                  <label>Premium Key</label>
                  <input id="manual-premium-key" type="text" placeholder="Enter premium key" />
                </div>
                <div>
                  <label>Discord User ID</label>
                  <input id="manual-premium-user-id" type="text" placeholder="Enter discord user id" />
                </div>
              </div>
              <button id="manual-activate-premium" class="btn btn-primary" style="margin-top: 10px;">Manual Activate Premium</button>
            </div>
          </div>
          <div data-subpanel="bot-ticket" style="display:none;">
            <p class="muted" style="margin-bottom:12px;">Ticket bot connection for ticket embed commands.</p>
            <div class="two-col grid">
              <div style="grid-column:1 / -1;">
                <label>Discord Application ID (Client ID)</label>
                <input id="ticket-bot-app-id" type="text" placeholder="Paste ticket bot application/client id" value="<%= settings.ticketBot && settings.ticketBot.appId ? settings.ticketBot.appId : '' %>" />
              </div>
              <div style="grid-column:1 / -1;">
                <label>Discord Bot Token</label>
                <input id="ticket-bot-token" type="password" placeholder="Paste ticket bot token" value="<%= settings.ticketBot && settings.ticketBot.token ? settings.ticketBot.token : '' %>" />
              </div>
              <div style="grid-column:1 / -1;">
                <label>Activation Token</label>
                <div class="row" style="gap:8px;">
                  <input id="ticket-bot-activation-token" readonly value="<%= settings.ticketBot && settings.ticketBot.activationToken ? settings.ticketBot.activationToken : '' %>" />
                  <button id="ticket-bot-copy-activation-token" class="btn btn-ghost">Copy</button>
                  <button id="ticket-bot-regenerate-activation-token" class="btn btn-ghost">Regenerate</button>
                </div>
              </div>
            </div>
            <button id="ticket-bot-save" class="btn btn-primary" style="margin-top: 12px;">Save Bot Config</button>
          </div>
        </div>
      </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
      const token = localStorage.getItem("jx_token");
      const toast = (msg) => {
        const el = document.getElementById("toast");
        el.textContent = msg;
        el.classList.add("show");
        setTimeout(() => el.classList.remove("show"), 2200);
      };
      if (!token) {
        window.location.href = "/login";
      }

      let jxRole = "owner"; // "owner" or "guest"

      async function loadSessionInfo() {
        try {
          const res = await fetch("/api/jx/auth/me", { headers: { Authorization: "Bearer " + token } });
          if (!res.ok) {
            throw new Error("Auth required");
          }
          const data = await res.json();
          if (!data.ok) throw new Error("Auth failed");
          jxRole = data.role || "owner";

          if (jxRole === "guest") {
            // Update title
            const t = document.getElementById("dash-title");
            if (t) t.textContent = "JX Guest Dashboard";

            // Hide pending requests stat
            const reqWrap = document.getElementById("stat-requests-wrap");
            if (reqWrap) reqWrap.style.display = "none";

            // Hide Request Key tab & panel
            const tabReq = document.getElementById("tab-sub-request");
            if (tabReq) tabReq.style.display = "none";
            const panelReq = document.getElementById("subpanel-request");
            if (panelReq) panelReq.style.display = "none";

            // Hide Settings tab entirely
            document.querySelectorAll(".tab[data-tab='tab-settings']").forEach((el) => {
              el.style.display = "none";
            });
            document.querySelectorAll(".tab[data-tab='tab-bot']").forEach((el) => {
              el.style.display = "none";
            });
            const settingsPanel = document.getElementById("tab-settings");
            if (settingsPanel) settingsPanel.style.display = "none";
            const botPanel = document.getElementById("tab-bot");
            if (botPanel) botPanel.style.display = "none";
          }
        } catch (err) {
          console.error(err);
          window.location.href = "/login";
        }
