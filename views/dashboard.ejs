      function applyKeySearch() {
        const tbody = document.querySelector("#keys-table tbody");
        const query = (document.getElementById("key-search").value || "").trim().toLowerCase();
        tbody.innerHTML = "";
        const rows = !query
          ? state.allKeys
          : state.allKeys.filter((k) => {
              const keyStr = String(k.key || "").toLowerCase();
              const hwidStr = String(k.hwid || "").toLowerCase();
              const tierStr = String(k.tier || "").toLowerCase();
              const statusStr = String(k.status || "").toLowerCase();
              return (
                keyStr.includes(query) ||
                hwidStr.includes(query) ||
                tierStr.includes(query) ||
                statusStr.includes(query)
              );
            });
        rows.forEach((k) => {
